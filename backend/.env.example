# === BASE DE DATOS L2JMobius (MySQL) ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_mysql
DB_NAME=l2jmobius      # nombre de tu base de datos del servidor

# === JWT (cambiar por clave secreta fuerte) ===
JWT_SECRET=cambia_esta_clave_secreta_l2h5_2026
JWT_EXPIRES_IN=7d

# === SERVIDOR WEB ===
PORT=3000
NODE_ENV=development

# === HASH DE CONTRASEÑAS L2JMobius ===
# 'sha1' (default L2JMobius) | 'md5' | 'bcrypt'
L2_PASS_HASH=sha1

# === CONFIGURACIÓN DEL SERVIDOR DE JUEGO ===
GAME_SERVER_NAME=Lineage 2 H5
MAX_CHARS_PER_ACCOUNT=3

# === ZONA PVP (nombres de las zonas del RotatingPvpZoneManager) ===
PVP_ZONE_1=Coliseo de Giran
PVP_ZONE_2=Catacumbas de los Sacrificados
